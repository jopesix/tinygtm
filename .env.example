# Supabase (tinygtm-suite project — shared with future TinyGTM tools)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude Haiku 4.5 default, Sonnet 4.6 as upgrade lever)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Jina Reader (URL → clean Markdown for the supporting-context fetcher).
# Optional — without a key the free tier (~20 RPM) is used. Get one at jina.ai.
JINA_API_KEY=

# Vercel KV (rate-limit + monthly $ cap counters)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Rate-limit config (overrides defaults if set)
RATE_LIMIT_ANON_PER_DAY=3
RATE_LIMIT_USER_PER_DAY=20
MONTHLY_COST_CAP_USD=20

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=faq-generator

# PostHog (shared TinyGTM analytics project)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
